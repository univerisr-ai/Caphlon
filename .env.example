# =============================================================================
# Caphlon — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values:  cp .env.example .env
#
# Not: Bağlı LLM sağlayıcısı/anahtarı (UNDERDOG_LLM_*) burada elle
# ayarlanmaz — `caphlon connect` ile bağlanır ve alt-süreçlere otomatik
# enjekte edilir (packages/caphlon/src/config/active.ts).

# --- Kovan Koordinatörü (docker compose up -d) ---
HIVE_PORT=8777
HIVE_QUORUM=3
HIVE_FED_QUORUM=3

# --- Caphlon kök dizini (opsiyonel) ---
# config.json, şifreli anahtarlar (credentials.enc) ve skills/ buranın
# altında yaşar. Varsayılan: ~/.caphlon
# CAPHLON_HOME=~/.caphlon

# --- Platform dizini (opsiyonel) ---
# Vendored araçların (core/*, MiMo-Code-main, open-design-main) evi.
# Varsayılan: repo checkout'u; global npm kurulumunda ~/.caphlon/platform
# (caphlon setup kurar). Elle sabitlemek için:
# CAPHLON_PLATFORM=~/.caphlon/platform
