# =============================================================================
# Project Underdog - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values:  cp .env.example .env

# --- Orchestrator ---
UNDERDOG_HOST=0.0.0.0
UNDERDOG_PORT=8800
UNDERDOG_URL=ws://localhost:8800/ws

# --- Task Configuration ---
UNDERDOG_MIN_WORKERS=3
UNDERDOG_CONSENSUS_THRESHOLD=0.5
UNDERDOG_TASK_TIMEOUT=300
UNDERDOG_HEARTBEAT=15

# --- Database ---
UNDERDOG_DB_URL=sqlite+aiosqlite:///data/underdog.db

# --- LLM / API ---
# Master teacher model (used in teacher-student loop)
UNDERDOG_LLM_PROVIDER=openai
UNDERDOG_LLM_MODEL=gpt-4o-mini
UNDERDOG_LLM_API_KEY=sk-your-key-here
UNDERDOG_LLM_BASE_URL=https://api.openai.com/v1
UNDERDOG_LLM_MAX_TOKENS=1024
UNDERDOG_LLM_TEMPERATURE=0.3

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=project-underdog

# --- Logging ---
UNDERDOG_LOG_LEVEL=INFO
UNDERDOG_LOG_FORMAT=json
DEBUG=false
