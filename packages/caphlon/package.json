{
  "name": "caphlon",
  "version": "0.2.0",
  "description": "Caphlon — Unified AI Agent Platform CLI. Qualixar OS + Open Design + MiMo Code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "bin": {
    "caphlon": "./bin/caphlon.js",
    "caph": "./bin/caphlon.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/univerisr-ai/Caphlon.git",
    "directory": "packages/caphlon"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "caphlon",
    "ai",
    "agent",
    "cli",
    "qualixar-os",
    "open-design",
    "mimo-code"
  ],
  "license": "MIT"
}
