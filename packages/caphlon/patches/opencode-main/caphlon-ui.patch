+// Caphlon ‚ÄĒ deniz ahtapotu. KullanńĪcńĪnńĪn sańüladńĪńüńĪ detaylńĪ g√∂lge-art'ńĪ temel
+// alńĪr. Ham art aŇüańüńĪda template literal olarak durur; `toLines` ortak girintiyi
+// otomatik kńĪrpar ve sondaki boŇüluklarńĪ temizler ‚ÄĒ yani art'ńĪ olduńüu gibi
+// yapńĪŇütńĪrabiliriz, hizalama kodda yapńĪlńĪr.
+
+function toLines(raw: string): string[] {
+  const lines = raw.replace(/^\n/, "").replace(/\s+$/, "").split("\n")
+  const indents = lines.filter((l) => l.trim().length > 0).map((l) => l.match(/^ */)![0].length)
+  const cut = indents.length ? Math.min(...indents) : 0
+  return lines.map((l) => l.slice(cut).replace(/\s+$/, ""))
