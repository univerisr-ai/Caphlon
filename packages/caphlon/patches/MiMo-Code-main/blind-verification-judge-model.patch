diff --git a/packages/opencode/test/session/max-mode-judge-model.test.ts b/packages/opencode/test/session/max-mode-judge-model.test.ts
--- /dev/null
+++ b/packages/opencode/test/session/max-mode-judge-model.test.ts
@@ -0,0 +1,74 @@
+import { describe, expect, test } from "bun:test"
+import { Effect } from "effect"
+import * as Stream from "effect/Stream"
+import { judge, type Candidate, type MaxStepInput } from "../../src/session/max-mode"
+import type { LLM } from "../../src/session/llm"
+
+/**
+ * Blind verification: when `judgeModel` is set, the judge call must go to that
+ * SEPARATE model — the generator model must not approve its own candidates.
+ * When unset, behavior is unchanged (falls back to the step model).
+ */
+
+/** Mock LLM that records which model each stream call was given. */
+function captureLLM() {
+  const models: unknown[] = []
+  const llm = {
+    buildSystemArray: () => Effect.succeed([]),
+    stream: (input: { model: unknown }): Stream.Stream<LLM.Event, unknown> => {
+      models.push(input.model)
+      return Stream.fromIterable([
+        { type: "text-delta", text: "1" } as LLM.Event,
+        { type: "finish-step", finishReason: "stop", usage: { inputTokens: 1, outputTokens: 1 } } as LLM.Event,
+      ])
+    },
+  } as unknown as LLM.Interface
+  return { llm, models }
+}
+
+const GENERATOR_MODEL = { info: { id: "generator" } }
+const JUDGE_MODEL = { info: { id: "independent-judge" } }
+
+function input(llm: LLM.Interface, judgeModel?: unknown): MaxStepInput {
+  return {
+    handle: {} as any,
+    llm,
+    user: {} as any,
+    agent: {} as any,
+    model: GENERATOR_MODEL as any,
+    judgeModel: judgeModel as any,
+    sessionID: "ses_test",
+    system: [],
+    messages: [],
+    tools: {},
+  }
+}
+
+const candidates = [
+  { index: 0, reasoning: "", text: "a", toolCalls: [], finishReason: "stop" },
+  { index: 1, reasoning: "", text: "b", toolCalls: [], finishReason: "stop" },
+] as unknown as Candidate[]
+
+describe("max-mode judge model (blind verification)", () => {
+  test("judge uses the separate judgeModel when configured", async () => {
+    const { llm, models } = captureLLM()
+    const result = await Effect.runPromise(judge(input(llm, JUDGE_MODEL), candidates))
+    expect(result.pick).toBe(1)
+    expect(models).toHaveLength(1)
+    expect(models[0]).toBe(JUDGE_MODEL)
+  })
+
+  test("judge falls back to the step model when judgeModel unset", async () => {
+    const { llm, models } = captureLLM()
+    await Effect.runPromise(judge(input(llm), candidates))
+    expect(models).toHaveLength(1)
+    expect(models[0]).toBe(GENERATOR_MODEL)
+  })
+
+  test("single candidate short-circuits without any judge call (either model)", async () => {
+    const { llm, models } = captureLLM()
+    const result = await Effect.runPromise(judge(input(llm, JUDGE_MODEL), candidates.slice(0, 1)))
+    expect(result.pick).toBe(0)
+    expect(models).toHaveLength(0)
+  })
+})
